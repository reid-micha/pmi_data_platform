# ════════════════════════════════════════════════════════════════════════════
# pmi_data_platform — env template (copy to `.env` and fill secrets).
# ════════════════════════════════════════════════════════════════════════════
#
# Bootstrap:  cp pmi_data_platform/.env.example pmi_data_platform/.env
#
# After editing the real .env, restart any running compose services so the
# new values are picked up:
#   docker compose --profile pmi --profile pmi-web up -d
#
# See the comments below for each block's purpose. Per-service .env files
# have been retired — this single file is the source of truth.

# ─── OpenAI / LLM (B: real LLM evaluator) ──────────────────────────────────
# Required once any CoreFactorModel is promoted with a real `gpt-*` model_id.
# Until then the deterministic stub is used and this can stay blank.
OPENAI_API_KEY=

# ─── Database (shared by pmi-core / pmi-api / pmi-ingest / pmi-workers) ────
# Inside docker compose, PMI_DB_HOST is overridden to `postgres` by the
# `environment:` block in docker-compose.yml. Leave this as `localhost` so
# host-side CLI invocations work transparently.
PMI_DB_HOST=localhost
PMI_DB_PORT=5432
PMI_DB_NAME=pmi
PMI_DB_USER=warindex
PMI_DB_PASSWORD=warindex
PMI_DB_SSL=false

# ─── MLflow tracking + Prompt Registry (pmi-core, pmi-workers) ─────────────
# In docker compose this is overridden to `http://mlflow:5000`.
PMI_MLFLOW_TRACKING_URI=http://localhost:5500
PMI_MLFLOW_ENABLED=true
PMI_MLFLOW_EXPERIMENT_PREFIX=pmi.

# ─── pmi-api ────────────────────────────────────────────────────────────────
# CORR-0.6: when true, every /indexes/* + /sources/health route requires
# `X-API-Key: <token>` (mint with `pmi-core keys create`, CORR-0.7). /health
# stays public for cloud-platform liveness probes. Flip to true in production.
PMI_API_REQUIRE_AUTH=false
PMI_API_CORS_ORIGINS=http://localhost:3000,http://localhost:3030,http://localhost:5173
PMI_API_PORT=8000

# ─── pmi-ingest ─────────────────────────────────────────────────────────────
POLYMARKET_BASE_URL=https://gamma-api.polymarket.com
POLYMARKET_POLL_INTERVAL_SEC=300
POLYMARKET_PAGE_SIZE=100
POLYMARKET_MAX_PAGES=1000

# A: mock data mode — bypass the live REST call and load fixtures from disk.
# Useful when the host network blocks gamma-api.polymarket.com (corporate
# proxy, DNS filter, etc.) or when iterating offline. Set to `true` to enable.
POLYMARKET_USE_MOCK=false
# Container path: bind-mounted at /app/fixtures inside pmi-ingest.
# Host path (for local CLI): pmi_data_platform/pmi-demo/fixtures/markets.json
POLYMARKET_MOCK_FIXTURE_PATH=/app/fixtures/markets.json

# Kalshi Elections REST — auth optional (blank = anonymous, lower rate limits).
# KALSHI_PRIVATE_KEY accepts an inline PEM (use \n for newlines) or a path.
KALSHI_BASE_URL=https://api.elections.kalshi.com
KALSHI_POLL_INTERVAL_SEC=300
KALSHI_PAGE_SIZE=1000
KALSHI_MAX_PAGES=200
KALSHI_API_KEY_ID=
KALSHI_PRIVATE_KEY=
# Kalshi orderbook poller (depth signal, Kalshi parity for CORR-4.3).
KALSHI_CLOB_POLL_INTERVAL_SEC=60
KALSHI_CLOB_CONCURRENCY=4
KALSHI_CLOB_MAX_PER_CYCLE=2000
# Kalshi WS (trade feed, Kalshi parity for CORR-4.1). REQUIRES the API key
# pair above — Kalshi has no anonymous WS.
#
# GOTCHA: a Kalshi API key that passes REST cleanly (200 on
# `/trade-api/v2/exchange/status`) is NOT automatically WS-enabled. WS
# handshake will return HTTP 401 + `{"code":"authentication_error",
# "details":"NOT_FOUND"}` even with a valid signature — Kalshi gates WS
# behind a separate "streaming" scope that market-data-only keys do not
# get by default. Enable it from the Kalshi developer console on the
# SAME `KALSHI_API_KEY_ID` (no code change needed). See module docstring
# at pmi-ingest/pmi_ingest/streams/kalshi_ws.py for the 2026-06-01 probe.
KALSHI_WS_TOKEN_REFRESH_SEC=60
KALSHI_WS_HEARTBEAT_SEC=60
KALSHI_WS_SUBSCRIBE_CHUNK=250
KALSHI_WS_MAX_TOKENS=1000

# ─── Polymarket deep signals (CORR-4.1 ~ 4.4) ──────────────────────────────
# CLOB orderbook depth poller (CORR-4.3) — drives aggregator liquidity weight.
POLYMARKET_CLOB_BASE_URL=https://clob.polymarket.com
POLYMARKET_CLOB_POLL_INTERVAL_SEC=60
POLYMARKET_CLOB_CONCURRENCY=16
POLYMARKET_CLOB_MAX_PER_CYCLE=5000

# Polymarket /prices-history backfill (CORR-3.10 / SHIP-4.5).
# `interval=max` gets ~200 evenly-spaced bars across each market's full
# life. Switch to 1w/1d for finer-grained recent data.
POLYMARKET_HISTORY_INTERVAL=max
POLYMARKET_HISTORY_FIDELITY_MIN=0
POLYMARKET_HISTORY_CONCURRENCY=8
POLYMARKET_HISTORY_MAX_PER_CYCLE=1000

# ─── Metaculus (REST + RSC, ported from legacy Micah) ──────────────────────
# `Token <key>` header (NOT `Bearer <key>` — Metaculus uses DRF TokenAuth).
# Get one at https://www.metaculus.com/accounts/profile/ → "API Token".
# Required for the list API since 2025 (`/api2/questions/` returns HTTP 403
# without it, even though the underlying questions are public on the web
# UI). The RSC fallback used for community prediction still works
# anonymously, so a 403 on the list endpoint zeroes out new-market
# discovery but does not block price refresh on already-known questions.
# Without this token, `metaculus-rest` will surface 403 as
# `status='down'` in audit_source_health — by design, not a bug.
METACULUS_API_TOKEN=
METACULUS_PAGE_SIZE=100
METACULUS_MAX_PAGES=200
METACULUS_RSC_CONCURRENCY=5

# ─── Playwright scrapers (Robinhood + Crypto.com) ──────────────────────────
# Both disabled by default — Chromium is bundled in the pmi-ingest image
# but the venues require explicit opt-in. Per-source enable flags below.
PLAYWRIGHT_HEADLESS=true
PLAYWRIGHT_VIEWPORT_WIDTH=1280
PLAYWRIGHT_VIEWPORT_HEIGHT=900
PLAYWRIGHT_NAVIGATION_TIMEOUT_MS=60000
PLAYWRIGHT_NAV_DELAY_SEC=2.0
PLAYWRIGHT_RETRY_MAX=3
PLAYWRIGHT_RETRY_BACKOFF_SEC=30.0

# Robinhood — flip to `true` to enable `pmi-ingest robinhood-scrape`.
ROBINHOOD_ENABLED=false
ROBINHOOD_BASE_URL=https://robinhood.com/us/en/prediction-markets/
ROBINHOOD_PAGE_LOAD_WAIT_SEC=5.0
ROBINHOOD_SCROLL_PAUSE_SEC=2.0
ROBINHOOD_MAX_SCROLL_ATTEMPTS=30
ROBINHOOD_MAX_NO_NEW_CONTENT_SCROLLS=3
ROBINHOOD_DISCOVERY_HOVER_WAIT_MS=1500
ROBINHOOD_SCRAPE_WORKERS=2

# Crypto.com — flip to `true` to enable `pmi-ingest crypto-scrape`.
CRYPTO_ENABLED=false
CRYPTO_PAGE_LOAD_WAIT_SEC=5.0
CRYPTO_MAX_SEE_MORE_CLICKS=50

# WebSocket trade feed (CORR-4.1) — long-running `pmi-ingest ws`.
POLYMARKET_WS_URL=wss://ws-subscriptions-clob.polymarket.com/ws/market
POLYMARKET_WS_TOKEN_REFRESH_SEC=60
POLYMARKET_WS_HEARTBEAT_SEC=60

# Polygon chain indexer (CORR-4.2). Leave POLYGON_RPC_URL blank to disable —
# `pmi-ingest chain` will then be a clean no-op. Set to an Alchemy / Quicknode
# / Infura URL when ready. Public RPC may require POLYGON_INDEXER_CHUNK_BLOCKS=500.
POLYGON_RPC_URL=
POLYGON_INDEXER_CHUNK_BLOCKS=2000
POLYGON_INDEXER_CHUNKS_PER_CYCLE=10
POLYGON_INDEXER_HEAD_LAG_BLOCKS=32
POLYGON_INDEXER_START_BLOCK=33373050
POLYGON_CTF_EXCHANGE_ADDRESS=0x4bFb41d5B3570DeFd03C39a9A4D8dE6Bd8B8982E
POLYGON_CTF_ADDRESS=0x4D97DCd97eC945f40cF65F87097ACe5EA0476045
POLYGON_UMA_OO_ADDRESS=0xeE3Afe347D5C74317041E2618C49534dAf887c24
POLYGON_UMA_ADAPTER_ADDRESS=0xCB1822859cEF82Cd2Eb4E6276C7D1d3D533DBD12

# Trader cohort rollup thresholds (CORR-4.2 sub-job).
COHORT_WINDOW_DAYS=30
COHORT_WHALE_THRESHOLD_USD=100000
COHORT_MID_THRESHOLD_USD=1000

# ─── pmi-workers ────────────────────────────────────────────────────────────
PMI_WORKERS_DEFAULT_INDEX=polymarket-war-index

# ─── pmi-web (Next.js — server-side + browser-side URLs) ───────────────────
# Browser-facing URL — must be reachable from the user's host (localhost).
NEXT_PUBLIC_PMI_API_URL=http://localhost:8001
# Server-side (SSR) URL — uses compose network hostname inside containers.
# Falls back to NEXT_PUBLIC_PMI_API_URL when unset.
PMI_API_URL=http://pmi-api:8000

# ─── Logging ────────────────────────────────────────────────────────────────
PMI_LOG_LEVEL=INFO

# ─── Postgres container bootstrap (used by compose `postgres` service) ─────
DB_USER=warindex
DB_PASSWORD=warindex
DB_NAME=warindex
DB_PORT=5432
MLFLOW_PORT=5500
PMI_WEB_PORT=3030
