# ════════════════════════════════════════════════════════════════════════════
# pmi_data_platform — env template (copy to `.env` and fill secrets).
# ════════════════════════════════════════════════════════════════════════════
#
# Bootstrap:  cp pmi_data_platform/.env.example pmi_data_platform/.env
#
# After editing the real .env, restart any running compose services so the
# new values are picked up:
#   docker compose --profile pmi --profile pmi-web up -d
#
# See the comments below for each block's purpose. Per-service .env files
# have been retired — this single file is the source of truth.

# ─── OpenAI / LLM (B: real LLM evaluator) ──────────────────────────────────
# Required once any CoreFactorModel is promoted with a real `gpt-*` model_id.
# Until then the deterministic stub is used and this can stay blank.
OPENAI_API_KEY=

# ─── Database (shared by pmi-core / pmi-api / pmi-ingest / pmi-workers) ────
# Inside docker compose, PMI_DB_HOST is overridden to `postgres` by the
# `environment:` block in docker-compose.yml. Leave this as `localhost` so
# host-side CLI invocations work transparently.
PMI_DB_HOST=localhost
PMI_DB_PORT=5432
PMI_DB_NAME=pmi
PMI_DB_USER=warindex
PMI_DB_PASSWORD=warindex
PMI_DB_SSL=false

# ─── MLflow tracking + Prompt Registry (pmi-core, pmi-workers) ─────────────
# In docker compose this is overridden to `http://mlflow:5000`.
PMI_MLFLOW_TRACKING_URI=http://localhost:5500
PMI_MLFLOW_ENABLED=true
PMI_MLFLOW_EXPERIMENT_PREFIX=pmi.

# ─── pmi-api ────────────────────────────────────────────────────────────────
PMI_API_REQUIRE_AUTH=false
PMI_API_CORS_ORIGINS=http://localhost:3000,http://localhost:3030,http://localhost:5173
PMI_API_PORT=8000

# ─── pmi-ingest ─────────────────────────────────────────────────────────────
POLYMARKET_BASE_URL=https://gamma-api.polymarket.com
POLYMARKET_POLL_INTERVAL_SEC=300
POLYMARKET_PAGE_SIZE=100
POLYMARKET_MAX_PAGES=1000

# A: mock data mode — bypass the live REST call and load fixtures from disk.
# Useful when the host network blocks gamma-api.polymarket.com (corporate
# proxy, DNS filter, etc.) or when iterating offline. Set to `true` to enable.
POLYMARKET_USE_MOCK=false
# Container path: bind-mounted at /app/fixtures inside pmi-ingest.
# Host path (for local CLI): pmi_data_platform/pmi-demo/fixtures/markets.json
POLYMARKET_MOCK_FIXTURE_PATH=/app/fixtures/markets.json

# ─── pmi-workers ────────────────────────────────────────────────────────────
PMI_WORKERS_DEFAULT_INDEX=polymarket-war-index

# ─── pmi-web (Next.js — server-side + browser-side URLs) ───────────────────
# Browser-facing URL — must be reachable from the user's host (localhost).
NEXT_PUBLIC_PMI_API_URL=http://localhost:8001
# Server-side (SSR) URL — uses compose network hostname inside containers.
# Falls back to NEXT_PUBLIC_PMI_API_URL when unset.
PMI_API_URL=http://pmi-api:8000

# ─── Logging ────────────────────────────────────────────────────────────────
PMI_LOG_LEVEL=INFO

# ─── Postgres container bootstrap (used by compose `postgres` service) ─────
DB_USER=warindex
DB_PASSWORD=warindex
DB_NAME=warindex
DB_PORT=5432
MLFLOW_PORT=5500
PMI_WEB_PORT=3030
