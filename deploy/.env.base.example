# ════════════════════════════════════════════════════════════════════════════
# deploy/.env.base — NON-SECRET production config. Copy to `.env.base` and edit.
#
# fetch-secrets.sh concatenates this with the Secrets Manager JSON to produce
# the final deploy/.env that docker-compose.prod.yml reads. Secrets (DB
# password, OpenAI key, dashboard API key, MLflow basic-auth hash, Kalshi key)
# come from Secrets Manager and MUST NOT be put here.
# ════════════════════════════════════════════════════════════════════════════

# ─── Image source (GHCR, built by .github/workflows/build-images.yml) ──────
IMAGE_REGISTRY=ghcr.io
IMAGE_OWNER=your-github-org-or-user        # lowercase
IMAGE_TAG=sha-xxxxxxx                       # pin to a built short SHA, never `latest`

# ─── AWS wiring ─────────────────────────────────────────────────────────────
AWS_REGION=us-east-1
AWS_LOG_GROUP=/pmi/prod
MLFLOW_S3_BUCKET=pmi-mlflow-artifacts-<acct>
PMI_DATA_DIR=/mnt/data                      # gp3 EBS mount holding pgdata

# ─── Domain / TLS (Caddy) ───────────────────────────────────────────────────
PMI_DOMAIN=example.com                       # → pmi.<d>, api.pmi.<d>, mlflow.pmi.<d>
ACME_EMAIL=ops@example.com
MLFLOW_BASICAUTH_USER=admin                  # hash is a secret (Secrets Manager)

# ─── Database (password is a secret) ───────────────────────────────────────
PMI_DB_USER=warindex
PMI_DB_NAME=pmi
PMI_DB_PORT=5432
PMI_DB_SSL=false

# ─── pmi-api — auth ON in prod (CORR-0.6). Mint the web key with             ─
#     `pmi-core keys create --label pmi-web` and store it as PMI_API_KEY in    ─
#     Secrets Manager.                                                          ─
PMI_API_REQUIRE_AUTH=true
PMI_API_PORT=8000
PMI_API_CORS_ORIGINS=https://pmi.example.com

# ─── pmi-web (browser API URL is baked at image build via the CI build-arg) ─
NEXT_PUBLIC_PMI_API_URL=https://api.pmi.example.com

# ─── Ingest cadence ─────────────────────────────────────────────────────────
POLYMARKET_BASE_URL=https://gamma-api.polymarket.com
POLYMARKET_POLL_INTERVAL_SEC=300
POLYMARKET_PAGE_SIZE=100
POLYMARKET_MAX_PAGES=1000
POLYMARKET_USE_MOCK=false
POLYMARKET_CLOB_BASE_URL=https://clob.polymarket.com
POLYMARKET_CLOB_POLL_INTERVAL_SEC=60
POLYMARKET_CLOB_CONCURRENCY=16
POLYMARKET_CLOB_MAX_PER_CYCLE=5000
POLYMARKET_HISTORY_INTERVAL=max
KALSHI_BASE_URL=https://api.elections.kalshi.com
KALSHI_POLL_INTERVAL_SEC=300
KALSHI_CLOB_POLL_INTERVAL_SEC=60

# ─── LLM — leave PMI_LLM_BASE_URL blank to use OpenAI directly (key is a      ─
#     secret). Set it to a self-hosted OpenAI-compatible endpoint later.       ─
PMI_LLM_BASE_URL=

# ─── MLflow ─────────────────────────────────────────────────────────────────
PMI_MLFLOW_ENABLED=true
PMI_MLFLOW_EXPERIMENT_PREFIX=pmi.

# ─── pmi-workers ────────────────────────────────────────────────────────────
PMI_WORKERS_DEFAULT_INDEX=polymarket-war-index

# ─── Logging / errors ───────────────────────────────────────────────────────
PMI_LOG_LEVEL=INFO
# SENTRY_DSN is optional; set in Secrets Manager (or here) to enable Sentry.
SENTRY_DSN=
SENTRY_ENVIRONMENT=production
